{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "调试 FastAPI 主服务",
      "type": "debugpy",
      "request": "launch",
      "module": "uvicorn",
      "args": [
        "app.main:app",
        "--host", "0.0.0.0",
        "--port", "8001"
      ],
      "cwd": "${workspaceFolder}/vehicle-agent/backend",
      "python": "${workspaceFolder}/vehicle-agent/backend/.venv/Scripts/python.exe",
      "env": {
        "PYTHONPATH": "${workspaceFolder}/vehicle-agent/backend"
      },
      "console": "integratedTerminal",
      "justMyCode": false
    },
    {
      "name": "调试 MCP Server (stdio)",
      "type": "debugpy",
      "request": "launch",
      "module": "app.mcp.server",
      "cwd": "${workspaceFolder}/vehicle-agent/backend",
      "python": "${workspaceFolder}/vehicle-agent/backend/.venv/Scripts/python.exe",
      "env": {
        "PYTHONPATH": "${workspaceFolder}/vehicle-agent/backend"
      },
      "console": "integratedTerminal",
      "justMyCode": false
    },
    {
      "name": "调试 MCP Server (SSE 模式)",
      "type": "debugpy",
      "request": "launch",
      "module": "app.mcp.server",
      "args": ["--sse"],
      "cwd": "${workspaceFolder}/vehicle-agent/backend",
      "python": "${workspaceFolder}/vehicle-agent/backend/.venv/Scripts/python.exe",
      "env": {
        "PYTHONPATH": "${workspaceFolder}/vehicle-agent/backend"
      },
      "console": "integratedTerminal",
      "justMyCode": false
    },
    {
      "name": "附加到运行中的进程",
      "type": "debugpy",
      "request": "attach",
      "processId": "${command:pickProcess}",
      "justMyCode": false
    },
    {
      "name": "附加到端口 5678 (远程调试)",
      "type": "debugpy",
      "request": "attach",
      "connect": {
        "host": "localhost",
        "port": 5678
      },
      "justMyCode": false,
      "pathMappings": [
        {
          "localRoot": "${workspaceFolder}/vehicle-agent/backend",
          "remoteRoot": "${workspaceFolder}/vehicle-agent/backend"
        }
      ]
    }
  ]
}
