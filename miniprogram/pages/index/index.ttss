/* 首页样式 */
.container {
  display: flex;
  flex-direction: column;
  align-items: center;
  min-height: 100vh;
  padding: 60rpx 40rpx;
  background: linear-gradient(180deg, #0f0f23 0%, #1a1a3e 100%);
}

.hero {
  text-align: center;
  margin-bottom: 80rpx;
  margin-top: 40rpx;
}

.title {
  display: block;
  font-size: 56rpx;
  font-weight: 800;
  color: #ff6b6b;
  margin-bottom: 16rpx;
}

.subtitle {
  display: block;
  font-size: 28rpx;
  color: #a0a0cc;
}

.user-section {
  width: 100%;
  margin-bottom: 60rpx;
}

.user-card {
  display: flex;
  align-items: center;
  gap: 24rpx;
  padding: 32rpx;
  background: rgba(255, 255, 255, 0.05);
  border-radius: 24rpx;
}

.avatar {
  width: 100rpx;
  height: 100rpx;
  border-radius: 50%;
  border: 4rpx solid rgba(255, 107, 107, 0.5);
}

.nickname {
  font-size: 32rpx;
  font-weight: 600;
  color: #ffffff;
}

.login-prompt {
  text-align: center;
  padding: 40rpx;
  background: rgba(255, 255, 255, 0.05);
  border-radius: 24rpx;
}

.login-prompt text {
  color: #a0a0cc;
  font-size: 26rpx;
}

.btn-enter {
  width: 80% !important;
  height: 96rpx;
  line-height: 96rpx;
  background: linear-gradient(135deg, #ff6b6b, #ff8e53);
  color: white;
  font-size: 32rpx;
  font-weight: 600;
  border-radius: 48rpx;
  border: none;
}
