<!--游戏页 - 猜词 + 排行榜-->
<view class="game-container">
  <!-- 等待状态 -->
  <block tt:if="{{status === 'idle'}}">
    <view class="waiting">
      <text class="waiting-icon">🎮</text>
      <text class="waiting-text">等待主播开始新一轮...</text>
    </view>
  </block>

  <!-- 进行中 -->
  <block tt:if="{{status === 'active'}}">
    <view class="game-active">
      <!-- 提示 + 倒计时 -->
      <view class="hint-bar">
        <view class="hint-content">
          <text class="hint-label">提示</text>
          <text class="hint-text">{{hint}}</text>
        </view>
        <view class="countdown-badge {{remainingSeconds <= 10 ? 'urgent' : ''}}">
          <text>{{remainingSeconds}}s</text>
        </view>
      </view>

      <!-- 输入区 -->
      <view class="input-section">
        <input
          class="guess-input"
          placeholder="输入你猜的词..."
          value="{{guessText}}"
          bindinput="onInputChange"
          confirm-type="send"
          bindconfirm="submitGuess"
          maxlength="50"
        />
        <button class="btn-guess" bindtap="submitGuess" disabled="{{submitting || !guessText}}">
          {{submitting ? '提交中...' : '猜！'}}
        </button>
      </view>

      <!-- 猜测结果 -->
      <view tt:if="{{guessResult}}" class="guess-result {{guessResult.isCorrect ? 'correct' : ''}}">
        <text class="result-message">{{guessResult.message}}</text>
        <text tt:if="{{guessResult.rank > 0}}" class="result-rank">当前排名: 第{{guessResult.rank}}名</text>
      </view>
    </view>
  </block>

  <!-- 已结束 -->
  <block tt:if="{{status === 'finished'}}">
    <view class="game-finished">
      <view class="answer-card">
        <text class="answer-label">正确答案</text>
        <text class="answer-value">{{lastAnswer}}</text>
      </view>
    </view>
  </block>

  <!-- 排行榜（公共区域） -->
  <view tt:if="{{leaderboard.length > 0}}" class="leaderboard-section">
    <view class="lb-header">
      <text class="lb-title">排行榜</text>
      <text class="lb-count">{{totalParticipants}}人参与</text>
    </view>
    <view class="lb-list">
      <view
        tt:for="{{leaderboard}}"
        tt:key="index"
        class="lb-item {{index < 3 ? 'top-' + index : ''}}"
      >
        <view class="lb-rank">
          <text tt:if="{{index === 0}}">🥇</text>
          <text tt:elif="{{index === 1}}">🥈</text>
          <text tt:elif="{{index === 2}}">🥉</text>
          <text tt:else>{{item.rank}}</text>
        </view>
        <view class="lb-info">
          <text class="lb-name">{{item.username}}</text>
          <text class="lb-guess">{{item.guessText}}</text>
        </view>
        <text class="lb-score">{{item.score}}%</text>
      </view>
    </view>
  </view>
</view>
