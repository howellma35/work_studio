# 服务端口
PORT=3000

# Redis 配置
REDIS_HOST=127.0.0.1
REDIS_PORT=6379
REDIS_PASSWORD=

# SQLite 数据库路径
DB_PATH=./data/raggame.db

# 硅基流动 SiliconFlow API (Embedding 模型)
# 注册地址: https://siliconflow.cn
EMBEDDING_API_KEY=your_siliconflow_api_key_here
EMBEDDING_API_URL=https://api.siliconflow.cn/v1/embeddings
EMBEDDING_MODEL=BAAI/bge-m3

# 语义匹配阈值 (0-1, 越高越严格)
SIMILARITY_THRESHOLD=0.75

# 每轮游戏时长 (秒)
ROUND_DURATION=60

# 每人每轮最大猜测次数
MAX_GUESSES_PER_ROUND=3
