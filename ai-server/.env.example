# =============================================================
# 本文件仅用于本地开发参考
# 
# 生产部署请使用统一的配置文件：
#   deploy/.env.example  → 复制为 deploy/.env
#
# 本项目的配置项已包含在 deploy/.env.example 中：
#   - LLM_API_KEY, LLM_API_BASE, LLM_DEFAULT_MODEL
#   - EMBEDDING_API_KEY, EMBEDDING_API_URL, EMBEDDING_MODEL
#   - QDRANT_HOST, QDRANT_PORT
#   - CORS_ORIGINS, LOG_LEVEL
# =============================================================

# 本地开发时，复制此文件为 .env 并填入真实值
# 或直接从 deploy/.env 复制过来

AI_PORT=8000
CORS_ORIGINS=*
LOG_LEVEL=INFO
LOG_DIR=logs

LLM_API_KEY=your-llm-api-key-here
LLM_API_BASE=https://dashscope.aliyuncs.com/compatible-mode/v1
LLM_DEFAULT_MODEL=deepseek-v4-flash

EMBEDDING_API_KEY=your-siliconflow-api-key-here
EMBEDDING_API_URL=https://api.siliconflow.cn/v1/embeddings
EMBEDDING_MODEL=BAAI/bge-m3
EMBEDDING_DIMENSION=1024

# 本地开发用 localhost，Docker 用 qdrant
QDRANT_HOST=localhost
QDRANT_PORT=6333

CHUNK_SIZE=500
CHUNK_OVERLAP=50
# AI 后端服务配置
AI_PORT=8000

# CORS 允许的源（逗号分隔，* 表示全部）
CORS_ORIGINS=*

# LLM API 配置（OpenAI 兼容接口）
# 支持百炼平台所有模型，如 DeepSeek V4 Flash、通义千问等
LLM_API_KEY=your-api-key-here
LLM_API_BASE=https://dashscope.aliyuncs.com/compatible-mode/v1
LLM_DEFAULT_MODEL=deepseek-v4-flash

# Embedding API 配置（SiliconFlow）
EMBEDDING_API_KEY=your-siliconflow-key-here
EMBEDDING_API_URL=https://api.siliconflow.cn/v1/embeddings
EMBEDDING_MODEL=BAAI/bge-m3
EMBEDDING_DIMENSION=1024

# Qdrant 向量数据库（本地开发用 localhost，Docker 用 qdrant）
QDRANT_HOST=localhost
QDRANT_PORT=6333

# 文本分块配置
CHUNK_SIZE=500
CHUNK_OVERLAP=50

# 日志级别
LOG_LEVEL=INFO
LOG_DIR=logs
