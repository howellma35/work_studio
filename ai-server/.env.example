# AI 后端服务配置
AI_PORT=8000

# CORS 允许的源（逗号分隔，* 表示全部）
CORS_ORIGINS=*

# LLM API 配置（百炼平台 OpenAI 兼容接口）
# 支持百炼平台所有模型，如 DeepSeek V4 Flash、通义千问等
LLM_API_KEY=your-api-key-here
LLM_API_BASE=https://dashscope.aliyuncs.com/compatible-mode/v1
LLM_DEFAULT_MODEL=deepseek-v4-flash

# 日志级别
LOG_LEVEL=INFO
LOG_DIR=logs
