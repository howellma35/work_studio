# 游戏后端配置
GAME_PORT=3001

# Embedding API 配置 (硅基流动 SiliconFlow)
EMBEDDING_API_KEY=your_api_key_here
EMBEDDING_API_URL=https://api.siliconflow.cn/v1/embeddings
EMBEDDING_MODEL=BAAI/bge-m3

# 游戏配置
SIMILARITY_THRESHOLD=0.75
ROUND_DURATION=60
MAX_GUESSES_PER_ROUND=3

# 日志
LOG_LEVEL=INFO
LOG_DIR=logs

# CORS
CORS_ORIGINS=*
