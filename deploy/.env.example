# =============================================================
# Mahongwei Studio — 统一环境变量配置
# 所有项目共用一份配置
# 复制此文件为 .env 后按需修改
# =============================================================

# ===== 服务器 =====
# Langfuse 认证回调地址（填公网 IP 或域名，不能填 localhost）
# 本地开发: 192.168.31.101
# 生产部署: 106.14.24.38 或 mahongwei.com.cn
SERVER_IP=192.168.31.101

# ===== AI Server (主项目) =====
AI_PORT=8000
CORS_ORIGINS=*
LOG_LEVEL=INFO
LOG_DIR=logs

# ===== LLM API (OpenAI 兼容接口) =====
LLM_API_KEY=your-llm-api-key-here
LLM_API_BASE=https://dashscope.aliyuncs.com/compatible-mode/v1
LLM_DEFAULT_MODEL=deepseek-v4-flash

# ===== Embedding API (SiliconFlow) =====
EMBEDDING_API_KEY=your-siliconflow-api-key-here
EMBEDDING_API_URL=https://cn-beijing.maas.aliyuncs.com/compatible-mode/v1
EMBEDDING_MODEL=text-embedding-v4
EMBEDDING_DIMENSION=1024

# ===== Qdrant 向量数据库 =====
QDRANT_HOST=qdrant
QDRANT_PORT=6333

# ===== 文本分块 =====
CHUNK_SIZE=500
CHUNK_OVERLAP=50

# =============================================================
#  Vehicle Agent (车载智能助手)
# =============================================================

BACKEND_PORT=8001
RUNTIME_PORT=4000
FRONTEND_PORT=5174
VITE_BACKEND_URL=http://192.168.31.101:8001

# Vehicle LLM（可复用上面的 LLM 配置，也可单独配置）
# LLM_MODEL=qwen-plus

# MCP Server
MCP_TRANSPORT=stdio
MCP_SERVER_URL=http://localhost:8765
MAP_SERVICE_PROVIDER=amap
# 高德地图 API 配置（从 https://console.amap.com 申请）
# REST API Key（后端路线规划 / POI 搜索用）
AMAP_API_KEY=your-amap-rest-api-key-here
# JS API Key（前端地图渲染用）
AMAP_JS_KEY=your-amap-js-api-key-here
# JS API 安全密钥（JS API 2.0 必须）
AMAP_JS_SECRET=your-amap-js-secret-here
AMAP_API_BASE=https://restapi.amap.com/v3

# Memory Module
MEMORY_ENABLED=false
CHROMA_PERSIST_DIR=./data/chroma
SQLITE_DB_PATH=./data/memory.db
# Vehicle Embedding（可复用上面的 EMBEDDING 配置）
# EMBEDDING_API_BASE=https://dashscope.aliyuncs.com/compatible-mode/v1
# EMBEDDING_MODEL=text-embedding-v3

# ChromaDB
CHROMA_PORT=8002

# Demo Vehicle Status
DEFAULT_VEHICLE_TEMP=22
DEFAULT_VEHICLE_USER_ID=demo_user_001

# ===== Redis（共享，所有服务可用）=====
REDIS_PASSWORD=redis123
# Redis 最大内存（防止吃光服务器内存，32GB 服务器建议 2560mb）
# 超限时自动淘汰最久未使用的数据（allkeys-lru）
REDIS_MAXMEMORY=2560mb

# =============================================================
#  Langfuse 可观测性（默认启动，无需 --profile langfuse）
# =============================================================

LANGFUSE_PORT=3000
LANGFUSE_DB_PASSWORD=changeme123
LANGFUSE_NEXTAUTH_SECRET=my-nextauth-secret-change-in-production
LANGFUSE_SECRET_KEY=my-secret-key-change-in-production
LANGFUSE_SALT=mysalt123
LANGFUSE_CLICKHOUSE_PASSWORD=clickhouse123
LANGFUSE_MINIO_ROOT_USER=minioadmin
LANGFUSE_MINIO_ROOT_PASSWORD=minioadmin123
# Langfuse API keys（注册 Langfuse 后从控制台获取）
LANGFUSE_PUBLIC_KEY=your-langfuse-public-key
# LANGFUSE_SECRET_KEY 已在上面配置
