# =============================================================
# Mahongwei Studio — 统一环境变量配置
# 复制此文件为 .env 后按需修改
# =============================================================

# ===== AI Server (ai-server) =====
AI_PORT=8000
CORS_ORIGINS=*
LOG_LEVEL=INFO
LOG_DIR=logs

# ===== LLM API (OpenAI 兼容接口) =====
# 支持百炼平台所有模型: DeepSeek V4 Flash, 通义千问 Plus/Max 等
# 也支持 OpenAI / DeepSeek / Moonshot 等任何兼容 API
LLM_API_KEY=your-llm-api-key-here
LLM_API_BASE=https://dashscope.aliyuncs.com/compatible-mode/v1
LLM_DEFAULT_MODEL=deepseek-v4-flash

# ===== Embedding API (SiliconFlow) =====
# 用于 RAG 知识库文档向量化
EMBEDDING_API_KEY=your-siliconflow-api-key-here
EMBEDDING_API_URL=https://api.siliconflow.cn/v1/embeddings
EMBEDDING_MODEL=BAAI/bge-m3
EMBEDDING_DIMENSION=1024

# ===== Qdrant 向量数据库 =====
QDRANT_HOST=qdrant
QDRANT_PORT=6333

# ===== Chunking 配置 =====
CHUNK_SIZE=500
CHUNK_OVERLAP=50

# ===== Langfuse 可观测性平台 =====
SERVER_IP=localhost
LANGFUSE_DB_PASSWORD=changeme123
LANGFUSE_CLICKHOUSE_PASSWORD=clickhouse123
LANGFUSE_REDIS_PASSWORD=redis123
LANGFUSE_MINIO_ROOT_USER=minioadmin
LANGFUSE_MINIO_ROOT_PASSWORD=minioadmin123
LANGFUSE_NEXTAUTH_SECRET=my-nextauth-secret-change-in-production
LANGFUSE_SECRET_KEY=my-secret-key-change-in-production
LANGFUSE_SALT=mysalt123
