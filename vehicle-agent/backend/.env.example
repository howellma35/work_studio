# ===== 服务配置 =====
# 后端服务端口
PORT=8001

# CORS 允许的源（逗号分隔，* 表示全部）
CORS_ORIGINS=*

# ===== LLM API 配置（百炼平台 OpenAI 兼容接口）=====
# 支持百炼平台所有模型，如 DeepSeek、通义千问等
LLM_API_KEY=your-api-key-here
LLM_API_BASE=https://dashscope.aliyuncs.com/compatible-mode/v1
LLM_MODEL=deepseek-v3

# ===== MCP Server 配置 =====
# MCP 传输方式: stdio 或 sse
MCP_TRANSPORT=stdio
# SSE 模式下的 MCP Server 地址
MCP_SERVER_URL=http://localhost:8765

# 地图服务提供商（使用高德地图进行真实路线规划）
MAP_SERVICE_PROVIDER=amap

# ===== Amap (高德地图) API Config =====
# Web service REST API Key (for backend route planning / POI search)
AMAP_API_KEY=e9bf56d1327245c8b57b65b94c561759
# JS API Key (for frontend map rendering)
AMAP_JS_KEY=d67a506ff38f7390eb21acdafcf13987
# JS API security secret (required for JS API 2.0)
AMAP_JS_SECRET=54c57f2dd15a71c3531be2b324bc5338
# Amap REST API base URL
AMAP_API_BASE=https://restapi.amap.com/v3

# ===== 记忆模块配置 =====
# ChromaDB 向量数据库持久化目录
CHROMA_PERSIST_DIR=./data/chroma
# SQLite 结构化记忆数据库路径
SQLITE_DB_PATH=./data/memory.db
# 嵌入模型配置（使用百炼平台兼容接口）
EMBEDDING_API_KEY=your-embedding-api-key-here
EMBEDDING_API_BASE=https://dashscope.aliyuncs.com/compatible-mode/v1
EMBEDDING_MODEL=text-embedding-v3

# ===== 可观测性 (LangFuse) 配置 =====
# LangFuse 用于追踪整个 LLM 链路: Agent 路由决策、工具调用、token 消耗
#
# 部署方式:
#   自托管: docker run -d -p 3000:3000 langfuse/langfuse
#   云服务: https://cloud.langfuse.com (有免费额度)
#
# 配置步骤:
#   1. 部署 LangFuse 服务
#   2. 在 LangFuse 控制台创建项目
#   3. 复制项目的 Public Key 和 Secret Key 到下方
#   4. 重启 AutoMind 服务
#   5. 在 LangFuse 控制台查看每次对话的 trace 树状图
#
# 注意: 若未配置 Langfuse，可通过 LangGraph Studio 进行本地可视化调试
#   安装: pip install langgraph-cli
#   启动: langgraph dev
LANGFUSE_HOST=http://localhost:3000
LANGFUSE_PUBLIC_KEY=pk-lf-xxx
LANGFUSE_SECRET_KEY=sk-lf-xxx

# ===== 日志 =====
LOG_LEVEL=INFO
LOG_DIR=logs

# ===== 模拟车辆状态（用于Demo演示）=====
DEFAULT_VEHICLE_TEMP=22
DEFAULT_VEHICLE_USER_ID=demo_user_001
