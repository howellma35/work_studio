# ===== 服务配置 =====
# 后端服务端口
PORT=8001

# CORS 允许的源（逗号分隔，* 表示全部）
CORS_ORIGINS=*

# ===== LLM API 配置（百炼平台 OpenAI 兼容接口）=====
# 支持百炼平台所有模型，如 DeepSeek、通义千问等
LLM_API_KEY=your-api-key-here
LLM_API_BASE=https://dashscope.aliyuncs.com/compatible-mode/v1
LLM_MODEL=deepseek-v3

# ===== MCP Server 配置 =====
# MCP 传输方式: stdio 或 sse
MCP_TRANSPORT=stdio
# SSE 模式下的 MCP Server 地址
MCP_SERVER_URL=http://localhost:8765

# 地图服务提供商（模拟，用于导航工具展示）
MAP_SERVICE_PROVIDER=amap

# ===== 记忆模块配置 =====
# ChromaDB 向量数据库持久化目录
CHROMA_PERSIST_DIR=./data/chroma
# SQLite 结构化记忆数据库路径
SQLITE_DB_PATH=./data/memory.db
# 嵌入模型配置（使用百炼平台兼容接口）
EMBEDDING_API_KEY=your-embedding-api-key-here
EMBEDDING_API_BASE=https://dashscope.aliyuncs.com/compatible-mode/v1
EMBEDDING_MODEL=text-embedding-v3

# ===== 可观测性 (LangFuse) 配置 =====
# LangFuse 服务地址（自托管默认 http://localhost:3000）
LANGFUSE_HOST=http://localhost:3000
# 在 LangFuse 控制台创建项目后获取
LANGFUSE_PUBLIC_KEY=pk-lf-xxx
LANGFUSE_SECRET_KEY=sk-lf-xxx

# ===== 日志 =====
LOG_LEVEL=INFO
LOG_DIR=logs

# ===== 模拟车辆状态（用于Demo演示）=====
DEFAULT_VEHICLE_TEMP=22
DEFAULT_VEHICLE_USER_ID=demo_user_001
