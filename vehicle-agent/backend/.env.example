# =============================================================
# 本文件仅用于本地开发参考
# 
# 生产部署请使用统一的配置文件：
#   deploy/.env.example  → 复制为 deploy/.env
#
# 本项目的配置项已包含在 deploy/.env.example 中：
#   - LLM_API_KEY, LLM_MODEL
#   - EMBEDDING_API_KEY, EMBEDDING_MODEL
#   - AMAP_API_KEY, AMAP_JS_KEY, AMAP_JS_SECRET (高德地图)
#   - MEMORY_ENABLED, CHROMA_PERSIST_DIR
#   - LANGFUSE_* (可观测性)
# =============================================================

# 本地开发时，复制此文件为 .env 并填入真实值
# 或直接从 deploy/.env 复制过来

# ===== Service Config =====
PORT=8001
CORS_ORIGINS=*

# ===== LLM API Config (Bailian platform OpenAI compatible) =====
LLM_API_KEY=your-api-key-here
LLM_API_BASE=https://dashscope.aliyuncs.com/compatible-mode/v1
LLM_MODEL=deepseek-v3

# ===== MCP Server Config =====
MCP_TRANSPORT=stdio
MCP_SERVER_URL=http://localhost:8765
MAP_SERVICE_PROVIDER=amap

# ===== Amap (高德地图) API Config =====
# 从 https://console.amap.com 申请
AMAP_API_KEY=your-amap-rest-api-key-here
AMAP_JS_KEY=your-amap-js-api-key-here
AMAP_JS_SECRET=your-amap-js-secret-here
AMAP_API_BASE=https://restapi.amap.com/v3

# ===== Memory Module Config =====
MEMORY_ENABLED=false
CHROMA_PERSIST_DIR=./data/chroma
SQLITE_DB_PATH=./data/memory.db
EMBEDDING_API_KEY=your-embedding-api-key-here
EMBEDDING_API_BASE=https://dashscope.aliyuncs.com/compatible-mode/v1
EMBEDDING_MODEL=text-embedding-v3

# ===== Observability (LangFuse) Config =====
LANGFUSE_BASE_URL=http://localhost:3000
LANGFUSE_PUBLIC_KEY=your-langfuse-public-key
LANGFUSE_SECRET_KEY=your-langfuse-secret-key

# ===== Logging =====
LOG_LEVEL=INFO
LOG_DIR=logs

# ===== Demo Vehicle Status =====
DEFAULT_VEHICLE_TEMP=22
DEFAULT_VEHICLE_USER_ID=demo_user_001

# ===== RAGFlow 知识库与跨会话记忆 =====
RAGFLOW_ENABLED=true
RAGFLOW_API_KEY=                  # 从 RAGFlow Web UI (localhost:9380) 创建 API Key
RAGFLOW_BASE_URL=http://localhost:9380
RAGFLOW_LLM_ID=                  # RAGFlow tenant 内的 LLM model ID
RAGFLOW_EMBD_ID=                 # RAGFlow tenant 内的 Embedding model ID
